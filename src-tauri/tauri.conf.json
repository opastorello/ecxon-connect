{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ecxon Connect",
  "version": "1.0.0",
  "identifier": "br.com.ecxon.connect",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Ecxon Connect",
        "width": 420,
        "height": 300,
        "minWidth": 380,
        "minHeight": 280,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: asset: https://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Ecxon Connect — agente ativo"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Agente local para diagnóstico de rede Ecxon",
    "longDescription": "Ecxon Connect é o agente local que permite ao site Ecxon Diagnóstico realizar testes de conectividade TCP e UDP raw, contornando limitações do navegador.",
    "publisher": "Ecxon Datacenter LTDA",
    "copyright": "Copyright © 2026 Ecxon Datacenter LTDA",
    "homepage": "https://www.ecxon.com.br",
    "windows": {
      "wix": {
        "language": ["pt-BR"]
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["PortugueseBR"],
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {}
}
